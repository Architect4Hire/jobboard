<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Central Package Management (Directory.Packages.props) requires an unambiguous restore:
    with more than one package source and no source mapping, NuGet fails every restore with
    NU1507. The machine-global NuGet.Config defines extra feeds (A4H, etc.); we clear those
    inherited sources here and pin nuget.org as the single source so the build is deterministic
    on any machine. Every package in Directory.Packages.props resolves from nuget.org.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
