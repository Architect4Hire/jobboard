<Project>

  <!--
    Central Package Management. Every <PackageReference> across the solution omits its Version and
    resolves it from a <PackageVersion> here, so a package is pinned in exactly one place.

    Versions are intentionally NOT pre-filled: Aspire 13 / .NET 10 and the Azure Service Bus
    integration ship fast, and a stale pin is worse than none. The scaffolding prompts
    (docs/scrub-prompts.md) add each package here as they introduce it — pin the version you install,
    verified against https://aspire.dev and nuget.org.

    The families you'll add, by area (names may shift between versions — verify):
      Aspire:        Aspire.Hosting.AppHost, Aspire.Hosting.PostgreSQL,
                     Aspire.Hosting.Azure.ServiceBus, Aspire.Hosting.Redis,
                     Aspire.Hosting.NodeJs (JavaScript app), plus the client integrations
                     (Aspire.Npgsql.EntityFrameworkCore.PostgreSQL, Aspire.Azure.Messaging.ServiceBus,
                     Aspire.StackExchange.Redis)
      EF Core:       Microsoft.EntityFrameworkCore.Design, Npgsql.EntityFrameworkCore.PostgreSQL
      Web / gateway: Yarp.ReverseProxy, Microsoft.AspNetCore.Authentication.JwtBearer
      Validation:    FluentValidation, FluentValidation.DependencyInjectionExtensions
      Testing:       xunit, Microsoft.NET.Test.Sdk, NSubstitute (or Moq),
                     Microsoft.AspNetCore.Mvc.Testing, Testcontainers.PostgreSql
  -->
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <!-- Example (uncomment + set the version you install):
    <PackageVersion Include="FluentValidation" Version="x.y.z" />
    <PackageVersion Include="Yarp.ReverseProxy" Version="x.y.z" />
    -->
  </ItemGroup>

</Project>
